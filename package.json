{
  "name": "psf-bch-api",
  "version": "7.0.0",
  "main": "psf-bch-api.js",
  "type": "module",
  "scripts": {
    "start": "node bin/server.js",
    "docs": "./node_modules/.bin/apidoc -i src/ -o docs",
    "lint": "standard --env mocha --fix",
    "test": "npm run lint && TEST=unit c8 mocha 'test/unit/**/*.js' --exit",
    "test:integration": "mocha --timeout 25000 'test/integration/**/*.js' --exit",
    "coverage": "c8 --reporter=html mocha 'test/unit/**/*.js' --exit"
  },
  "author": "Chris Troutner <chris.troutner@gmail.com>",
  "license": "MIT",
  "description": "REST API proxy to Bitcoin Cash infrastructure",
  "dependencies": {
    "@psf/bch-js": "6.8.3",
    "axios": "1.7.7",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "5.1.0",
    "minimal-slp-wallet": "5.13.3",
    "slp-token-media": "1.2.10",
    "winston": "3.11.0",
    "winston-daily-rotate-file": "4.7.1",
    "x402-bch-express": "1.1.1"
  },
  "devDependencies": {
    "apidoc": "1.2.0",
    "c8": "10.1.3",
    "chai": "6.2.0",
    "mocha": "11.7.4",
    "sinon": "21.0.0",
    "standard": "17.1.2"
  },
  "apidoc": {
    "title": "psf-bch-api",
    "url": "http://localhost:3070"
  }
}
